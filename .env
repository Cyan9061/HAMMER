# ===========================================
# API Keys Configuration
# ===========================================

# Primary OpenAI API Key (for general usage)
OPENAI_API_KEY=sk-

# Special OpenAI API Key (for knowledge base and insight agent)
OPENAI_KB_API_KEY=sk-

# SiliconFlow API Keys Pool
SILICONFLOW_API_KEYS=sk-,sk-...

# Additional API Keys Pool  
ADDITIONAL_API_KEYS=sk-

# ===========================================
# Model Configuration
# ===========================================

# Default Models
DEFAULT_CHAT_MODEL=gpt-4o-mini
DEFAULT_EMBEDDING_MODEL=text-embedding-3-large
DEFAULT_EMBEDDING_MODEL_ALT=text-embedding-ada-002

# GPT Models
GPT_35_TURBO=gpt-3.5-turbo
GPT_4O_MINI=gpt-4o-mini
GPT_4O=gpt-4o
GPT_O1=o1
GPT_O3_MINI=o3-mini
GPT_35_TURBO_AZURE=gpt-35-turbo

# Gemini Models
GEMINI_PRO=gemini-1.5-pro-002
GEMINI_FLASH=gemini-1.5-flash-002
GEMINI_FLASH_LITE=gemini-2.0-flash-lite-preview-02-05
GEMINI_THINKING=gemini-2.0-flash-thinking-exp-01-21
GEMINI_PRO_EXP=gemini-2.0-pro-exp-02-05
GEMINI_FLASH_001=gemini-2.0-flash-001

# DeepSeek Models
DEEPSEEK_R1=deepseek-ai/DeepSeek-R1
DEEPSEEK_V3=deepseek-ai/DeepSeek-V3

# DataRobot Models
DATAROBOT_MODEL=datarobot/model-name
DATAROBOT_DEEPSEEK=datarobot/DeepSeek-Llama

# Claude Models
CLAUDE_SONNET=claude-3-5-sonnet-v2@20241022
CLAUDE_HAIKU=claude-3-5-haiku@20241022

# LLaMA Models
LLAMA_8B=llama3.1-8b
LLAMA_70B=llama-3.3-70b

# ===========================================
# Embedding Models Configuration
# ===========================================

# Local Embedding Model Path (if used)
# Comma-separated list of embedding models for MCTS search
# Example: Optional_EMBED_MODEL=/path/to/model1,/path/to/model2,/path/to/model3
# If empty, will use default hardcoded models in hierarchical_search.py
Optional_EMBED_MODEL=

# ===========================================
# Other Configuration
# ===========================================

# Environment
ENVIRONMENT=development
